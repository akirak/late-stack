{
  "name": "personal-blog",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "NITRO_PRESET=deno_deploy vite build && rm -rf dist && cp -r .output dist && cp -r data dist/",
    "start": "cd dist && deno task --config deno.json start",
    "deploy": "cd dist && deno run --allow-all jsr:@deno/deployctl deploy --project=tanstack-blog server/index.mjs",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint .",
    "lint-fix": "eslint --fix .",
    "lint-staged": "lint-staged",
    "test-e2e": "pnpm exec playwright test",
    "test-e2e:chromium": "pnpm exec playwright test --project=chromium",
    "test-e2e-report": "pnpm exec playwright show-report",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@clerk/tanstack-react-start": "^1.3.1",
    "@tanstack/react-router": "^1.170.8",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.12",
    "browserslist": "^4.28.2",
    "effect": "^3.21.2",
    "expressive-code": "^0.42.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "html-rewriter-wasm": "^0.4.1",
    "lightningcss": "^1.32.0",
    "react": "19.2.6",
    "react-aria-components": "^1.17.0",
    "react-dom": "19.2.6",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-expressive-code": "^0.42.0",
    "remark-captions": "^2.2.4",
    "remark-custom-header-id": "^1.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@deno/vite-plugin": "^2.0.2",
    "@effect/language-service": "^0.86.1",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/sql": "^0.51.1",
    "@effect/sql-sqlite-node": "^0.52.0",
    "@eslint-react/eslint-plugin": "^5.8.5",
    "@expressive-code/plugin-collapsible-sections": "^0.42.0",
    "@playwright/test": "^1.60.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@storybook/react-vite": "^10.4.1",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@tanstack/nitro-v2-vite-plugin": "^1.155.0",
    "@types/node": "^25.9.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "better-sqlite3": "12.10.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-xml-parser": "^5.8.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "hast-util-to-string": "^3.0.1",
    "lefthook": "^2.1.8",
    "lint-staged": "^17.0.5",
    "playwright": "^1.60.0",
    "reading-time": "^1.5.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "storybook": "^10.4.1",
    "tsx": "^4.22.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,yaml}": [
      "eslint --fix"
    ]
  }
}
