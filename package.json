{
  "name": "personal-blog",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "NITRO_PRESET=deno_deploy vite build && rm -rf dist && cp -r .output dist && cp -r data dist/",
    "start": "cd dist && deno task --config deno.json start",
    "deploy": "cd dist && deno run --allow-all jsr:@deno/deployctl deploy --project=tanstack-blog server/index.mjs",
    "typecheck": "tsc --noEmit",
    "dev-ladle": "pnpm ladle dev --viteConfig vite.config.ladle.ts",
    "lint": "eslint .",
    "lint-fix": "eslint --fix .",
    "lint-staged": "lint-staged",
    "test-e2e": "pnpm exec playwright test",
    "test-e2e:chromium": "pnpm exec playwright test --project=chromium",
    "test-e2e-report": "pnpm exec playwright show-report",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@clerk/tanstack-react-start": "^1.2.3",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-start": "^1.167.65",
    "browserslist": "^4.28.2",
    "effect": "^3.21.2",
    "expressive-code": "^0.41.7",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "html-rewriter-wasm": "^0.4.1",
    "lightningcss": "^1.32.0",
    "react": "19.2.4",
    "react-aria-components": "^1.17.0",
    "react-dom": "19.2.4",
    "react-lite-youtube-embed": "^3.5.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-expressive-code": "^0.41.7",
    "remark-captions": "^2.2.4",
    "remark-custom-header-id": "^1.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@deno/vite-plugin": "^1.0.6",
    "@effect/language-service": "^0.81.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/sql": "^0.51.1",
    "@effect/sql-sqlite-node": "^0.52.0",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@expressive-code/plugin-collapsible-sections": "^0.41.7",
    "@ladle/react": "^5.1.1",
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "@tanstack/nitro-v2-vite-plugin": "^1.154.9",
    "@types/node": "^25.6.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "better-sqlite3": "12.8.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-xml-parser": "^5.7.3",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "hast-util-to-string": "^3.0.1",
    "lefthook": "^2.1.6",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "pnpm": "^10.33.4",
    "reading-time": "^1.5.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vite": "^7.3.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,yaml}": [
      "eslint --fix"
    ]
  }
}
